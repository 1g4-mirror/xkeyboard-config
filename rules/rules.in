# if compat:
! layout[first]	 variant[first]		= compat
  de		 neo			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 adnw			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 koy			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 bone			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 bone_eszett_home	= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 neo_qwertz		= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 neo_qwerty		= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  jp		$sun_compat		= complete+japan(kana_lock):%i

! layout[later]	 variant[later]		= compat
  de		 neo			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 adnw			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 koy			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 bone			= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 bone_eszett_home	= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 neo_qwertz		= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  de		 neo_qwerty		= +caps(caps_lock):%i+misc(assign_shift_left_action):%i+level5(level5_lock):%i
  jp		$sun_compat		= +japan(kana_lock):%i

# endif

! model		layout[single]	=	compat
  pc98		jp		=	pc98(basic)
  *		jp		=	complete+japan
  olpc		*		=	olpc
  olpcm		*		=	olpc
  *		*		=	complete

! model		layout[1]	=	compat
  *		jp		=	complete+japan
  *		*		=	complete

! model		layout[later]	=	compat
  *		jp		=	+japan

! model		=	types
 $applealu	=	complete+numpad(mac)
  *		=	complete

! layout[any]	option					= symbols
  *		misc:apl				= +apl(level3):%i
  *		misc:typo				= +typo(base):%i
  *		lv3:ralt_alt				= +level3(ralt_alt):%i
  *		grp:toggle				= +group(toggle):%i
  *		grp:alts_toggle				= +group(alts_toggle):%i
  *		grp:alt_altgr_toggle			= +group(alt_altgr_toggle):%i
  *		grp:alt_space_toggle			= +group(alt_space_toggle):%i
  *		grp:win_space_toggle			= +group(win_space_toggle):%i
  *		grp:ctrl_space_toggle			= +group(ctrl_space_toggle):%i
  *		grp:rctrl_rshift_toggle			= +group(rctrl_rshift_toggle):%i
  *		grp:shifts_toggle			= +group(shifts_toggle):%i
 $azerty	caps:digits_row				= +capslock(digits_row):%i
 $azerty	caps:digits_row_independent_lock	= +capslock(digits_row_independent_lock):%i

! option				= 	symbols
# if compat:
  grp:shift_caps_switch			=	+group(caps_select)			// Delete in July 2027
  grp:win_menu_switch			=	+group(win_menu_select)			// Delete in July 2027
  grp:lctrl_rctrl_switch		=	+group(ctrl_select)			// Delete in July 2027
  ctrl:swapcaps_hyper			=	+ctrl(hyper_capscontrol)		// Delete in September 2027
  ctrl:swapcaps_and_switch_layout	= 	+ctrl(swapcaps)+group(lctrl_toggle)	// Delete in September 2027
# endif
